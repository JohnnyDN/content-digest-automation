      "parameters": {
        "jsCode": "// ============================================\n// CALCULATE CYCLE TOPIC\n// ============================================\n\nconst topics = ['AI', 'Finance', 'Music', 'Science'];\nconst cycleDay = Math.floor(Date.now() / (3 * 24 * 60 * 60 * 1000));\nconst cycleIndex = cycleDay % topics.length;\nconst currentTopic = topics[cycleIndex];\n\n// ============================================\n// CALCULATE 3-DAY PERIOD\n// ============================================\n\nconst now = new Date();\n\n// Period Start: 3 days ago at midnight\nconst periodStart = new Date();\nperiodStart.setDate(now.getDate() - 3);\nperiodStart.setHours(0, 0, 0, 0);\n\n// Period End: Yesterday at midnight\nconst periodEnd = new Date();\nperiodEnd.setDate(now.getDate() - 1);\nperiodEnd.setHours(0, 0, 0, 0);\n\n// Helper function for local date formatting\nfunction formatLocalDate(date) {\n  const year = date.getFullYear();\n  const month = String(date.getMonth() + 1).padStart(2, '0');\n  const day = String(date.getDate()).padStart(2, '0');\n  return `${year}-${month}-${day}`;\n}\n\n// ============================================\n// RETURN COMPLETE STATE\n// ============================================\n\nreturn [{\n  json: {\n    current_topic: currentTopic,\n    cycle_index: cycleIndex,\n    period_start: formatLocalDate(periodStart),\n    period_end: formatLocalDate(periodEnd),\n    calculated_at: new Date().toISOString()\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        -64
      ],
      "id": "3981df31-d7f3-4d6a-9caf-7d11eaee4e2f",
      "name": "Set 3 days Cycle Topic"
    },
