        "jsCode": "// Get data from previous nodes\nconst topic = $('Set 3 days Cycle Topic').first().json.current_topic;\nconst sourcesData = $input.first().json;\n\n// Calculate current cycle number for reference\nconst now = new Date();\nconst cycleDay = Math.floor(now.getTime() / (3 * 24 * 60 * 60 * 1000)) % 4;\n\nreturn [{\n  json: {\n    topic: topic,\n    workflow_id: 0,\n    event: 'cycle_start',\n    status: 'success',\n    details: {\n      activated_topic: sourcesData.activated_topic,\n      active_sources_count: sourcesData.active_count,\n      cycle_index: cycleDay,\n      timestamp: new Date().toISOString()\n    }\n  }\n}];"
      },
